# API Base URL (leave empty to use Next.js rewrites which proxy to localhost)
NEXT_PUBLIC_API_BASE_URL=

# Backend API direct URL (used by Next.js rewrites)
BACKEND_API_URL=http://localhost:8000

# Chatbot backend URL (used by Next.js rewrites)
CHATBOT_URL=http://localhost:8001

# WebSocket base URL for chat streaming
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:80
